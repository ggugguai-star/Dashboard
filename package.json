{
  "name": "work-dashboard",
  "productName": "업무 대시보드",
  "version": "1.2.0",
  "description": "업무 대시보드 — Electron 앱",
  "main": "main.js",
  "author": "dashboard",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/download-fonts.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.work.dashboard",
    "productName": "업무 대시보드",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "C:\\Users\\ggugg\\OneDrive\\Desktop\\dashboard-dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "업무 대시보드",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    },
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "ggugguai-star",
      "repo": "Dashboard",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
