{
  "name": "work-dashboard",
  "productName": "업무 대시보드",
  "version": "1.3.2",
  "description": "업무 대시보드 — Electron 앱",
  "main": "main.js",
  "author": "dashboard",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/download-fonts.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "release": "electron-builder --win --publish always",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.work.dashboard",
    "productName": "업무 대시보드",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "C:\\Users\\ggugg\\OneDrive\\Desktop\\dashboard-dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "업무 대시보드",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    },
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "ggugguai-star",
      "repo": "Dashboard",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "electron-updater": "^6.8.3",
    "mammoth": "^1.9.0",
    "xlsx": "^0.18.5"
  }
}
